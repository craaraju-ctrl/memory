# =============================================================================
#  agentic-memory — Environment Configuration
# =============================================================================
# Copy this file to use as your configuration:
#   cp .env.example .env
# =============================================================================

# ── Database ─────────────────────────────────────────────────────────────────

# Path to the SQLite database file.
# Use ":memory:" for an in-memory database (data lost on restart).
# Default: ":memory:"
MEMORY_DB_PATH=/path/to/memory.db

# ── Server ───────────────────────────────────────────────────────────────────

# Host and port for the HTTP API server.
# Default: "0.0.0.0:3111"
MEMORY_ADDR=0.0.0.0:3111

# ── Embeddings (Ollama) ──────────────────────────────────────────────────────

# Base URL for the Ollama server (for embedding generation).
# If not set, embedding endpoints will return 503 Service Unavailable.
# Default: (optional, embedding disabled if unset)
# Example: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model to use for generating embeddings.
# Default: (optional, embedding disabled if unset)
# Recommended: nomic-embed-text (768 dims), mxbai-embed-large (1024 dims)
# Example: nomic-embed-text
OLLAMA_MODEL=nomic-embed-text

# ── Vector Search ────────────────────────────────────────────────────────────

# Dimension for vector embeddings stored in sqlite-vec vec0 tables.
# Must match the output dimension of the embedding model.
# Common values: 384 (all-minilm), 768 (nomic-embed-text), 1024 (mxbai-embed-large)
# Clamped to [64, 4096]. Default: 768
# VECTOR_DIMENSION=768
